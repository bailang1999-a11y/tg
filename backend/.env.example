APP_ENV=development
APP_PORT=8080
DATABASE_DSN=host=localhost user=codex3 password=codex3 dbname=codex3 port=5432 sslmode=disable TimeZone=Asia/Shanghai
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
NATS_URL=nats://localhost:4222
JWT_SECRET=replace-with-a-long-random-secret
AUTO_MIGRATE=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TELEGRAM_SYNC_PYTHON=./.venv/bin/python
TELEGRAM_SYNC_SCRIPT=./scripts/telegram_profile_sync.py
TELEGRAM_SYNC_TIMEOUT_SECONDS=25
TELEGRAM_APPLY_SCRIPT=./scripts/telegram_profile_apply.py
TELEGRAM_APPLY_TIMEOUT_SECONDS=90
