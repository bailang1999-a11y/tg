POSTGRES_DB=codex3
POSTGRES_USER=codex3
POSTGRES_PASSWORD=replace-with-strong-database-password

REDIS_PASSWORD=replace-with-strong-redis-password
JWT_SECRET=replace-with-at-least-32-random-characters

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_EMAIL=admin@example.com

# 后台 API 允许的浏览器来源。上线后改成你的域名，例如 https://ops.example.com
CORS_ORIGINS=http://localhost:8088,http://127.0.0.1:8088

# 对外端口：WEB_PORT 是前端控制台；HTTP_PORT 是后端 API 直连端口，通常只在内网排查时使用。
WEB_PORT=8088
HTTP_PORT=8080

DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=40
WORKER_CONCURRENCY=8
TASK_RUN_LOCK_STALE_SECONDS=93600
TASK_QUEUE_ACK_WAIT_SECONDS=93600
TASK_QUEUE_MAX_DELIVER=5
LOG_RETENTION_DAYS=30
